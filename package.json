{
  "name": "agente-helpdesk-pro",
  "version": "1.0.0",
  "description": "Agente Helpdesk Pro - Suporte Inteligente e Acesso Remoto",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "chart.js": "^4.4.1",
    "ssh2": "^1.17.0"
  },
  "author": "IT Support Pro Team",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "electron-packager": "^17.1.2"
  },
  "build": {
    "appId": "com.helpdesk.agent.pro",
    "win": {
      "target": "nsis",
      "icon": "src/assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Agente Helpdesk Pro",
      "runAfterFinish": true
    },
    "extraResources": [
      {
        "from": "assets",
        "to": "assets",
        "filter": [
          "meshagent64.exe",
          "meshagentarm64.exe"
        ]
      }
    ]
  }
}
